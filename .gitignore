# =============================================================================
# Terraform + Terragrunt .gitignore
# =============================================================================

# =============================================================================
# Terraform
# =============================================================================

# Local .terraform directories (provider plugins, modules cache, etc.)
**/.terraform/*
**/.terraform.lock.hcl
application/
# Terraform state files - NEVER commit these to version control.
# Use remote backends (S3, GCS, Azure Blob, Terraform Cloud, etc.) instead.
*.tfstate
*.tfstate.*

# Crash log files generated by Terraform CLI
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data,
# such as passwords, private keys, and other secrets. These should not be
# part of version control as they are data points which are potentially
# sensitive and subject to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally
# and so are not checked in.
override.tf
override.tf.json
*_override.tf
*__override.tf.json

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform plan output files (if you use -out=tfplan)
*tfplan*

# =============================================================================
# Terragrunt
# =============================================================================

# Terragrunt cache directory where downloaded modules and generated files are stored.
# This directory is recreated at runtime and should never be committed.
**/.terragrunt-cache/*

# Terragrunt stack output directory (used by `terragrunt stack generate`)
**/.terragrunt-stack/*

# Provider cache directory if using Terragrunt provider caching
# (e.g., --terragrunt-provider-cache or TERRAGRUNT_PROVIDER_CACHE_DIR)
.terragrunt-provider-cache/

# =============================================================================
# Secrets & Sensitive Files
# =============================================================================

# SSH keys
*.pem
*.key
*.pub
id_rsa
id_ed25519

# AWS credentials and config
.aws/
.aws/credentials
.aws/config

# Azure credentials
.azure/

# GCP credentials
*.json.key
service-account*.json

# Environment files that may contain secrets
.env
.envrc
.env.local
.env.*.local

# =============================================================================
# IDE / Editor
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# IntelliJ / PyCharm / GoLand / WebStorm
.idea/
*.iml

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
*~
\#*\#

# =============================================================================
# OS Generated Files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# =============================================================================
# Misc
# =============================================================================

# Log files
*.log

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Empty-folder placeholders
**/.gitkeep
**/.keep

# tenv / tfenv version manager
.tenv
.tfenv